{
  "name": "go-template-lsp",
  "displayName": "Go Template LSP (Language Server)",
  "description": "Language Server Protocol extension for Go templates: validation, intellisense, go to definition, and more.",
  "version": "0.2.0",
  "publisher": "Dr. Abiira Nathan",
  "repository": {
    "url": "https://github.com/abiiranathan/go-template-lsp.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "go",
    "golang",
    "template",
    "html",
    "lsp",
    "language server",
    "validation",
    "intellisense",
    "autocomplete",
    "definition",
    "go-template-lsp"
  ],
  "activationEvents": [
    "workspaceContains:**/*.go",
    "workspaceContains:**/go.mod",
    "onLanguage:html",
    "onLanguage:go-template"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gotpl.validate",
        "title": "GoTpl: Validate Template Variables",
        "icon": "$(check-all)"
      },
      {
        "command": "gotpl.rebuildIndex",
        "title": "GoTpl: Rebuild Template Index",
        "icon": "$(refresh)"
      },
      {
        "command": "gotpl.showKnowledgeGraph",
        "title": "GoTpl: Show Template Knowledge Graph"
      },
      {
        "command": "gotpl.goToRenderCall",
        "title": "GoTpl: Go to Render Call",
        "category": "GoTpl"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "gotpl.validate",
          "when": "resourceExtname == .html || resourceExtname == .tmpl",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == go-template || resourceExtname == .html || resourceExtname == .tmpl",
          "command": "gotpl.goToRenderCall",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Go Template LSP",
      "properties": {
        "gotpl.goAnalyzerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the gotpl analyzer binary. Leave empty to use the bundled binary."
        },
        "gotpl.sourceDir": {
          "type": "string",
          "default": ".",
          "description": "Go source directory relative to the workspace root, passed as the -dir flag to the CLI (e.g. 'sample' if your Go files live in a subdirectory)."
        },
        "gotpl.templateRoot": {
          "type": "string",
          "default": "",
          "description": "Root directory for templates, relative to sourceDir, passed as the -template-root flag (e.g. 'templates')."
        },
        "gotpl.templateBaseDir": {
          "type": "string",
          "default": "",
          "description": "Base directory for templates, relative to the workspace root, used as the -template-base-dir flag. If empty, defaults to the workspace root."
        },
        "gotpl.contextFile": {
          "type": "string",
          "default": "",
          "description": "Path to a JSON file containing additional context variables (e.g. injected by middleware). Can be absolute or relative to workspace root."
        },
        "gotpl.debounceMs": {
          "type": "number",
          "default": 1500,
          "description": "Debounce delay in milliseconds before re-validating on file change."
        },
        "gotpl.compress": {
          "type": "boolean",
          "default": false,
          "description": "Enable GZIP compression from analyzer"
        },
        "gotpl.validate": {
          "type": "boolean",
          "default": true,
          "description": "Validate variables passed into the context and template names"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build-analyzer",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-analyzer": "cd ../analyzer && go build -ldflags='-w -s -extldflags=\"-static\"' -o ../extension/out/gotpl-analyzer .",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}